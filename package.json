{
  "name": "doorstep",
  "version": "0.1.0",
  "description": "A barebones SCSS framework for small web projects.",
  "license": "MIT",
  "scripts": {
    "build": "sass example/style.scss example/style.css",
    "build:prod": "sass example/style.scss example/style.css --style=compressed --no-source-map",
    "watch:sass": "sass --watch example/style.scss example/style.css",
    "watch:serve": "browser-sync start --server example --files \"example/*.css, example/*.html\" --no-notify",
    "dev": "npm-run-all --parallel watch:sass watch:serve"
  },
  "devDependencies": {
    "browser-sync": "^3.0.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.0"
  }
}
